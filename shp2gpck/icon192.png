<svg xmlns="http://www.w3.org/2000/svg" width="192" height="192" viewBox="0 0 192 192">
  <rect width="192" height="192" rx="24" fill="#2d1f0e"/>
  <!-- Topo grid -->
  <g stroke="#5c3d1e" stroke-width="0.8" opacity="0.6">
    <line x1="32" y1="0"   x2="32" y2="192"/>
    <line x1="64" y1="0"   x2="64" y2="192"/>
    <line x1="96" y1="0"   x2="96" y2="192"/>
    <line x1="128" y1="0"  x2="128" y2="192"/>
    <line x1="160" y1="0"  x2="160" y2="192"/>
    <line x1="0"  y1="32"  x2="192" y2="32"/>
    <line x1="0"  y1="64"  x2="192" y2="64"/>
    <line x1="0"  y1="96"  x2="192" y2="96"/>
    <line x1="0"  y1="128" x2="192" y2="128"/>
    <line x1="0"  y1="160" x2="192" y2="160"/>
  </g>
  <!-- Polygon shape (stylized geological formation) -->
  <polygon points="40,140 60,80 100,60 148,90 155,140 110,155 70,152"
           fill="#4a8a3a" fill-opacity="0.35" stroke="#6aaa5a" stroke-width="2.5"/>
  <!-- Arrow down (conversion) -->
  <path d="M96 68 L96 108 M84 96 L96 110 L108 96"
        stroke="#c8832a" stroke-width="5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
  <!-- Label C2 -->
  <text x="96" y="148" font-family="serif" font-weight="700" font-size="22"
        fill="#e8a040" text-anchor="middle">C2</text>
  <!-- Bottom label -->
  <text x="96" y="178" font-family="monospace" font-size="11" fill="#7a6040" text-anchor="middle">shp2gpck</text>
</svg>
